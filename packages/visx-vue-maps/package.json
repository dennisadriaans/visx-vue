{
  "name": "@visx-vue/maps",
  "version": "0.1.0",
  "description": "High-level dotted map components for visx-vue",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack src/index.ts --format esm,cjs --dts",
    "test": "vp test"
  },
  "dependencies": {
    "@turf/boolean-point-in-polygon": "7.3.1",
    "proj4": "2.20.2"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}

{
  "name": "@visx-vue/xychart",
  "version": "0.0.0",
  "description": "visx xychart components and utilities for Vue",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack src/index.ts --format esm,cjs --dts",
    "test": "vp test"
  },
  "dependencies": {
    "@visx-vue/annotation": "workspace:*",
    "@visx-vue/axis": "workspace:*",
    "@visx-vue/event": "workspace:*",
    "@visx-vue/glyph": "workspace:*",
    "@visx-vue/grid": "workspace:*",
    "@visx-vue/responsive": "workspace:*",
    "@visx-vue/scale": "workspace:*",
    "@visx-vue/shape": "workspace:*",
    "@visx-vue/spring": "workspace:*",
    "@visx-vue/text": "workspace:*",
    "@visx-vue/tooltip": "workspace:*",
    "@visx-vue/vendor": "workspace:*",
    "@visx-vue/voronoi": "workspace:*",
    "d3-interpolate-path": "^2.3.0",
    "lodash": "^4.17.21",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.13"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}

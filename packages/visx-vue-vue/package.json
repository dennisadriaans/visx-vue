{
  "name": "@visx-vue/vue",
  "version": "0.0.0",
  "description": "One stop install for all visx-vue packages",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack src/index.ts --format esm,cjs --dts",
    "test": "vp test"
  },
  "dependencies": {
    "@visx-vue/annotation": "workspace:*",
    "@visx-vue/axis": "workspace:*",
    "@visx-vue/bounds": "workspace:*",
    "@visx-vue/brush": "workspace:*",
    "@visx-vue/chord": "workspace:*",
    "@visx-vue/clip-path": "workspace:*",
    "@visx-vue/curve": "workspace:*",
    "@visx-vue/delaunay": "workspace:*",
    "@visx-vue/drag": "workspace:*",
    "@visx-vue/event": "workspace:*",
    "@visx-vue/geo": "workspace:*",
    "@visx-vue/glyph": "workspace:*",
    "@visx-vue/gradient": "workspace:*",
    "@visx-vue/grid": "workspace:*",
    "@visx-vue/group": "workspace:*",
    "@visx-vue/heatmap": "workspace:*",
    "@visx-vue/hierarchy": "workspace:*",
    "@visx-vue/legend": "workspace:*",
    "@visx-vue/marker": "workspace:*",
    "@visx-vue/mock-data": "workspace:*",
    "@visx-vue/network": "workspace:*",
    "@visx-vue/pattern": "workspace:*",
    "@visx-vue/point": "workspace:*",
    "@visx-vue/responsive": "workspace:*",
    "@visx-vue/sankey": "workspace:*",
    "@visx-vue/scale": "workspace:*",
    "@visx-vue/shape": "workspace:*",
    "@visx-vue/spring": "workspace:*",
    "@visx-vue/stats": "workspace:*",
    "@visx-vue/text": "workspace:*",
    "@visx-vue/threshold": "workspace:*",
    "@visx-vue/tooltip": "workspace:*",
    "@visx-vue/vendor": "workspace:*",
    "@visx-vue/voronoi": "workspace:*",
    "@visx-vue/wordcloud": "workspace:*",
    "@visx-vue/xychart": "workspace:*",
    "@visx-vue/zoom": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
{
  "name": "@visx-vue/spring",
  "version": "0.0.0",
  "description": "visx animated components for Vue using spring transitions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack src/index.ts --format esm,cjs --dts",
    "test": "vp test"
  },
  "dependencies": {
    "@visx-vue/axis": "workspace:*",
    "@visx-vue/grid": "workspace:*",
    "@visx-vue/scale": "workspace:*",
    "@visx-vue/text": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}